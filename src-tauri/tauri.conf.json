{
  "productName": "Logbird",
  "version": "0.1.0",
  "identifier": "com.logbird.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUzMTJBREU2MEU4REMxNApSV1FVM09oZzNpb3hEbGFkMVpmYWNQSWhiQUkrUUc3blMwRXNHVExUK2NXZ1BYcVRBZ2RpM3AzVQo=",
      "endpoints": [
        "https://app.logbird.me/latest.json"
      ]
    }
  }
}
